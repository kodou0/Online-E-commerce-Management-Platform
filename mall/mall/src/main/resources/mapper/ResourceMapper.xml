<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.lc.mapper.ResourceMapper">
    <select id="getListByRole" resultType="com.lc.model.entity.Resource">
        SELECT r.* FROM resource r LEFT JOIN role_resource rr ON r.id = rr.resource_id
        WHERE rr.role_id = #{roleId}
    </select>
</mapper>
